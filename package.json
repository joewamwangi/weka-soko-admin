// ── MINI BAR CHART ─────────────────────────────────────────────────────────────
function BarChart({ data, valueKey, labelKey }) {
  const max = Math.max(...data.map(d => d[valueKey]));
  return (
    <div className="chart-bar">
      {data.map(d => (
        <div key={d[labelKey]} className="c-bar" style={{ height: `${(d[valueKey] / max) * 100}%` }}>
          <span className="c-bar-val">{d[valueKey].toLocaleString()}</span>
          <span className="c-bar-label">{d[labelKey]}</span>
        </div>
      ))}
    </div>
  );
}

// ── LOGIN ──────────────────────────────────────────────────────────────────────
function Login({ onLogin }) {
  const [email, setEmail] = useState("");
  const [pass, setPass] = useState("");
  const [err, setErr] = useState("");
  const [step, setStep] = useState("creds"); // creds | otp
  const [otp, setOtp] = useState("");

  const submit = () => {
    if (email === "admin@wekasoko.co.ke" && pass === "admin123") {
      setStep("otp");
    } else {
      setErr("Invalid credentials. Use admin@wekasoko.co.ke / admin123");
    }
  };

  const verify = () => {
    if (otp === "123456") {
      onLogin({ name: "Admin", email });
    } else {
      setErr("Invalid OTP. Use 123456 for demo.");
    }
  };

  return (
    <div className="login-wrap">
      <div className="login-box">
        <div style={{ textAlign: "center", marginBottom: 28 }}>
          <h2 style={{ fontSize: 24, fontWeight: 800 }}>Weka<span style={{ color: "#00C853" }}>Soko</span></h2>
          <p style={{ color: "#555", fontSize: 13, marginTop: 4 }}>Admin Panel — Restricted Access</p>
        </div>
        {err && <div className="alert alert-r" style={{ marginBottom: 16 }}>{err}</div>}
        {step === "creds" ? (
          <>
            <div style={{ marginBottom: 14 }}>
              <label style={{ display: "block", fontSize: 11, color: "#555", marginBottom: 6, textTransform: "uppercase", letterSpacing: ".05em" }}>Admin Email</label>
              <input className="inp" style={{ width: "100%" }} value={email} onChange={e => setEmail(e.target.value)} placeholder="admin@wekasoko.co.ke" />
            </div>
            <div style={{ marginBottom: 20 }}>
              <label style={{ display: "block", fontSize: 11, color: "#555", marginBottom: 6, textTransform: "uppercase", letterSpacing: ".05em" }}>Password</label>
              <input className="inp" type="password" style={{ width: "100%" }} value={pass} onChange={e => setPass(e.target.value)} onKeyDown={e => e.key === "Enter" && submit()} placeholder="••••••••" />
            </div>
            <button className="btn bp" style={{ width: "100%", padding: "12px" }} onClick={submit}>Continue →</button>
          </>
        ) : (
          <>
            <div className="alert alert-g" style={{ marginBottom: 16 }}>📧 OTP sent to {email}. Demo: use <strong>123456</strong></div>
            <div style={{ marginBottom: 20 }}>
              <label style={{ display: "block", fontSize: 11, color: "#555", marginBottom: 6, textTransform: "uppercase", letterSpacing: ".05em" }}>Enter OTP</label>
              <input className="inp" style={{ width: "100%", fontSize: 20, textAlign: "center", letterSpacing: ".3em" }} value={otp} onChange={e => setOtp(e.target.value)} maxLength={6} placeholder="——————" />
            </div>
            <button className="btn bp" style={{ width: "100%", padding: "12px" }} onClick={verify} disabled={otp.length < 6}>Verify & Sign In</button>
          </>
        )}
        <p style={{ textAlign: "center", marginTop: 16, fontSize: 11, color: "#333" }}>🔒 This area is restricted to platform administrators only.</p>
      </div>
    </div>
  );
}

// ── OVERVIEW PAGE ──────────────────────────────────────────────────────────────
function Overview({ data }) {
  const s = data.stats;
  return (
    <div>
      <div className="sec-title">📊 Platform Overview</div>

      {/* KEY STATS */}
      <div className="stat-grid">
        <div className="stat"><div className="stat-val" style={{ color: "#00C853" }}>{s.totalUsers.toLocaleString()}</div><div className="stat-lbl">Total Users</div><div className="stat-sub">+{s.newUsersToday} today · +{s.newUsersWeek} this week</div></div>
        <div className="stat"><div className="stat-val">{s.activeListings}</div><div className="stat-lbl">Active Ads</div><div className="stat-sub">{s.totalListings.toLocaleString()} total</div></div>
        <div className="stat"><div className="stat-val">{s.soldListings.toLocaleString()}</div><div className="stat-lbl">Ads Sold</div><div className="stat-sub">{((s.soldListings/s.totalListings)*100).toFixed(1)}% conversion</div></div>
        <div className="stat"><div className="stat-val" style={{ color: "#FFD600" }}>{fmtKES(s.totalRevenue)}</div><div className="stat-lbl">Total Revenue</div><div className="stat-sub">Unlocks + Escrow fees</div></div>
        <div className="stat"><div className="stat-val">{s.pendingUnlocks}</div><div className="stat-lbl">Pending Unlocks</div><div className="stat-sub">{fmtKES(s.pendingUnlocks * 250)} potential</div></div>
        <div className="stat"><div className="stat-val">{s.activeEscrows}</div><div className="stat-lbl">Active Escrows</div><div className="stat-sub">{fmtKES(s.escrowVolume)} held</div></div>
        <div className="stat"><div className="stat-val" style={{ color: "#FF3D3D" }}>{s.flaggedAccounts}</div><div className="stat-lbl">Flagged Accounts</div><div className="stat-sub">{s.suspendedAccounts} suspended</div></div>
        <div className="stat"><div className="stat-val" style={{ color: "#FF3D3D" }}>{s.openDisputes}</div><div className="stat-lbl">Open Disputes</div><div className="stat-sub">Needs review</div></div>
      </div>

      <div className="two-col" style={{ marginBottom: 20 }}>
        {/* REVENUE CHART */}
        <div className="card" style={{ padding: 20 }}>
          <div className="sec-title" style={{ fontSize: 14, marginBottom: 4 }}>📈 Monthly Revenue (KSh)</div>
          <div style={{ height: 140, position: "relative", paddingBottom: 24 }}>
            <BarChart data={data.revenueByMonth} valueKey="r" labelKey="m" />
          </div>
        </div>

        {/* REVENUE BREAKDOWN */}
        <div className="card" style={{ padding: 20 }}>
          <div className="sec-title" style={{ fontSize: 14, marginBottom: 16 }}>💰 Revenue Breakdown</div>
          {[
            { label: "Unlock Fees (KSh 250 each)", val: s.unlockRevenue, pct: Math.round(s.unlockRevenue / s.totalRevenue * 100) },
            { label: "Escrow Fees (2.5%)", val: s.escrowFees, pct: Math.round(s.escrowFees / s.totalRevenue * 100) },
          ].map(r => (
            <div key={r.label} style={{ marginBottom: 16 }}>
              <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 6, fontSize: 12 }}>
                <span style={{ color: "#888" }}>{r.label}</span>
                <span style={{ fontWeight: 700 }}>{fmtKES(r.val)}</span>
              </div>
              <div className="bar-wrap">
                <div className="bar-bg"><div className="bar-fill" style={{ width: r.pct + "%" }} /></div>
                <span style={{ fontSize: 11, color: "#555", minWidth: 32 }}>{r.pct}%</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* CATEGORY BREAKDOWN */}
      <div className="card" style={{ padding: 20, marginBottom: 20 }}>
        <div className="sec-title" style={{ fontSize: 14, marginBottom: 16 }}>🏷 Ads by Category</div>
        <table>
          <thead><tr><th>Category</th><th>Active Ads</th><th>Total Sold</th><th>Performance</th></tr></thead>
          <tbody>
            {data.categoryBreakdown.sort((a, b) => b.sold - a.sold).map(c => (
              <tr key={c.cat}>
                <td style={{ fontWeight: 600 }}>{c.cat}</td>
                <td>{c.count}</td>
                <td><span className="badge bg">{c.sold}</span></td>
                <td>
                  <div className="bar-wrap">
                    <div className="bar-bg" style={{ width: 100 }}><div className="bar-fill" style={{ width: Math.round(c.sold / Math.max(...data.categoryBreakdown.map(x => x.sold)) * 100) + "%" }} /></div>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
}

// ── USERS PAGE ─────────────────────────────────────────────────────────────────
function Users({ data, onAction }) {
  const [search, setSearch] = useState("");
  const [filter, setFilter] = useState("all");
  const filtered = data.users.filter(u => {
    const ms = !search || u.name.toLowerCase().includes(search.toLowerCase()) || u.email.includes(search);
    const mf = filter === "all" || u.status === filter || u.role === filter;
    return ms && mf;
  });
  return (
    <div>
      <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 20 }}>
        <div className="sec-title" style={{ marginBottom: 0 }}>👥 Users ({data.users.length})</div>
      </div>
      <div style={{ display: "flex", gap: 10, marginBottom: 16, flexWrap: "wrap" }}>
        <input className="inp" placeholder="Search name or email..." value={search} onChange={e => setSearch(e.target.value)} style={{ flex: 1, minWidth: 200 }} />
        <select className="inp" value={filter} onChange={e => setFilter(e.target.value)}>
          <option value="all">All Users</option>
          <option value="seller">Sellers</option>
          <option value="buyer">Buyers</option>
          <option value="flagged">Flagged</option>
          <option value="suspended">Suspended</option>
        </select>
      </div>
      <div className="card">
        <table>
          <thead><tr><th>Name</th><th>Role</th><th>Phone</th><th>Joined</th><th>Status</th><th>Violations</th><th>Actions</th></tr></thead>
          <tbody>
            {filtered.map(u => (
              <tr key={u.id}>
                <td><div style={{ fontWeight: 600 }}>{u.name}</div><div style={{ fontSize: 11, color: "#555" }}>{u.email}</div></td>
                <td><span className={`badge ${u.role === "seller" ? "bgo" : "bgb"}`}>{u.role}</span></td>
                <td style={{ color: "#888" }}>{u.phone}</td>
                <td style={{ color: "#555", fontSize: 12 }}>{u.joined}</td>
                <td><span className={`badge ${u.status === "active" ? "bg" : u.status === "flagged" ? "bgo" : "bgr"}`}>{u.status}</span></td>
                <td>{u.violations > 0 ? <span style={{ color: "#FF3D3D", fontWeight: 700 }}>{u.violations}</span> : <span style={{ color: "#333" }}>0</span>}</td>
                <td>
                  <div style={{ display: "flex", gap: 6 }}>
                    {u.status !== "suspended" && <button className="btn br bsm" onClick={() => onAction("suspend", u)}>Suspend</button>}
                    {u.status === "suspended" && <button className="btn bs bsm" onClick={() => onAction("unsuspend", u)}>Restore</button>}
                    {u.status === "flagged" && <button className="btn bo bsm" onClick={() => onAction("dismiss", u)}>Dismiss</button>}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
}

// ── LISTINGS PAGE ──────────────────────────────────────────────────────────────
function Listings({ data }) {
  const [search, setSearch] = useState("");
  const filtered = data.listings.filter(l => !search || l.title.toLowerCase().includes(search.toLowerCase()) || l.seller.includes(search));
  return (
    <div>
      <div className="sec-title">📦 All Listings</div>
      <input className="inp" placeholder="Search listings..." value={search} onChange={e => setSearch(e.target.value)} style={{ width: "100%", marginBottom: 16 }} />
      <div className="card">
        <table>
          <thead><tr><th>Title</th><th>Seller</th><th>Price</th><th>Category</th><th>Status</th><th>Views</th><th>Created</th></tr></thead>
          <tbody>
            {filtered.map(l => (
              <tr key={l.id}>
                <td>
                  <div style={{ fontWeight: 600 }}>{l.title}</div>
                  {l.flagged && <span className="badge bgr" style={{ marginTop: 4 }}>⚠️ Flagged</span>}
                </td>
                <td style={{ color: "#888", fontSize: 12 }}>{l.seller}</td>
                <td style={{ fontWeight: 700, color: "#00C853" }}>{fmtKES(l.price)}</td>
                <td><span className="badge bgm">{l.category}</span></td>
                <td><span className={`badge ${l.status === "active" ? "bg" : "bgm"}`}>{l.status}</span></td>
                <td style={{ color: "#888" }}>{l.views}</td>
                <td style={{ color: "#555", fontSize: 12 }}>{l.created}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
}

// ── VIOLATIONS PAGE ────────────────────────────────────────────────────────────
function Violations({ data, onAction }) {
  const unreviewed = data.violations.filter(v => !v.reviewed).length;
  return (
    <div>
      <div className="sec-title">🚨 Chat Violations</div>
      {unreviewed > 0 && <div className="alert alert-y" style={{ marginBottom: 16 }}>⚠️ {unreviewed} violation{unreviewed > 1 ? "s" : ""} pending review</div>}
      <div className="card">
        <table>
          <thead><tr><th>User</th><th>Listing</th><th>Blocked Message</th><th>Severity</th><th>Date</th><th>Actions</th></tr></thead>
          <tbody>
            {data.violations.map(v => (
              <tr key={v.id}>
                <td><div style={{ fontWeight: 600 }}>{v.user}</div><div style={{ fontSize: 11, color: "#555" }}>{v.email}</div></td>
                <td style={{ color: "#888", fontSize: 12 }}>{v.listing}</td>
                <td><div style={{ background: "rgba(255,61,61,.08)", border: "1px solid rgba(255,61,61,.15)", borderRadius: 6, padding: "6px 10px", fontSize: 12, color: "#FF8888", fontStyle: "italic", maxWidth: 220 }}>{v.message}</div></td>
                <td><span className={`badge ${v.severity === "warning" ? "bgo" : v.severity === "flagged" ? "bo" : "bgr"}`}>{v.severity}</span></td>
                <td style={{ color: "#555", fontSize: 12 }}>{v.date}</td>
                <td>
                  {!v.reviewed ? (
                    <div style={{ display: "flex", gap: 6, flexWrap: "wrap" }}>
                      <button className="btn bs bsm" onClick={() => onAction("dismiss_violation", v)}>Dismiss</button>
                      <button className="btn bo bsm" onClick={() => onAction("warn_user", v)}>Warn</button>
                      <button className="btn br bsm" onClick={() => onAction("suspend_user", v)}>Suspend</button>
                    </div>
                  ) : <span className="badge bgm">Reviewed</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
}

// ── ESCROW PAGE ────────────────────────────────────────────────────────────────
function Escrow({ data, onAction }) {
  return (
    <div>
      <div className="sec-title">🔐 Escrow Management</div>
      <div className="stat-grid" style={{ gridTemplateColumns: "repeat(auto-fill,minmax(150px,1fr))", marginBottom: 20 }}>
        <div className="stat"><div className="stat-val">{data.escrows.filter(e => e.status === "holding").length}</div><div className="stat-lbl">Holding</div></div>
        <div className="stat"><div className="stat-val" style={{ color: "#FF3D3D" }}>{data.escrows.filter(e => e.status === "disputed").length}</div><div className="stat-lbl">Disputed</div></div>
        <div className="stat"><div className="stat-val" style={{ color: "#00C853" }}>{data.escrows.filter(e => e.status === "released").length}</div><div className="stat-lbl">Released</div></div>
        <div className="stat"><div className="stat-val" style={{ color: "#FFD600" }}>{fmtKES(data.stats.escrowFees)}</div><div className="stat-lbl">Fees Earned</div></div>
      </div>
      <div className="card" style={{ marginBottom: 20 }}>
        <table>
          <thead><tr><th>Listing</th><th>Buyer</th><th>Seller</th><th>Amount</th><th>Fee (2.5%)</th><th>Status</th><th>Release At</th><th>Actions</th></tr></thead>
          <tbody>
            {data.escrows.map(e => (
              <tr key={e.id}>
                <td style={{ fontWeight: 600 }}>{e.listing}</td>
                <td style={{ color: "#888", fontSize: 12 }}>{e.buyer}</td>
                <td style={{ color: "#888", fontSize: 12 }}>{e.seller}</td>
                <td style={{ fontWeight: 700 }}>{fmtKES(e.amount)}</td>
                <td style={{ color: "#FFD600" }}>{fmtKES(e.fee)}</td>
                <td><span className={`badge ${e.status === "holding" ? "bgo" : e.status === "disputed" ? "bgr" : "bg"}`}>{e.status}</span></td>
                <td style={{ color: "#555", fontSize: 12 }}>{e.releaseAt}</td>
                <td>
                  {(e.status === "holding" || e.status === "disputed") && (
                    <div style={{ display: "flex", gap: 6 }}>
                      <button className="btn bp bsm" onClick={() => onAction("release_escrow", e)}>Release →</button>
                      <button className="btn br bsm" onClick={() => onAction("refund_escrow", e)}>Refund</button>
                    </div>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {/* DISPUTES */}
      {data.disputes.length > 0 && <>
        <div className="sec-title" style={{ fontSize: 14 }}>⚖️ Open Disputes</div>
        <div className="card">
          <table>
            <thead><tr><th>Listing</th><th>Raised By</th><th>Reason</th><th>Amount</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
              {data.disputes.map(d => (
                <tr key={d.id}>
                  <td style={{ fontWeight: 600 }}>{d.listing}</td>
                  <td style={{ color: "#888" }}>{d.raisedBy}</td>
                  <td style={{ fontSize: 12, color: "#888", maxWidth: 200 }}>{d.reason}</td>
                  <td style={{ fontWeight: 700 }}>{fmtKES(d.amount)}</td>
                  <td><span className={`badge ${d.status === "open" ? "bgr" : "bg"}`}>{d.status}</span></td>
                  <td>
                    {d.status === "open" && (
                      <div style={{ display: "flex", gap: 6 }}>
                        <button className="btn bp bsm" onClick={() => onAction("resolve_seller", d)}>→ Seller</button>
                        <button className="btn bs bsm" onClick={() => onAction("resolve_buyer", d)}>→ Buyer</button>
                      </div>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </>}
    </div>
  );
}

// ── PAYMENTS PAGE ──────────────────────────────────────────────────────────────
function Payments({ data }) {
  return (
    <div>
      <div className="sec-title">💳 Payment Records</div>
      <div className="card">
        <table>
          <thead><tr><th>Type</th><th>Payer</th><th>Listing</th><th>Amount</th><th>Status</th><th>Date</th><th>M-Pesa Receipt</th></tr></thead>
          <tbody>
            {data.payments.map(p => (
              <tr key={p.id}>
                <td><span className={`badge ${p.type === "unlock" ? "bg" : "bgo"}`}>{p.type}</span></td>
                <td style={{ fontWeight: 600 }}>{p.payer}</td>
                <td style={{ color: "#888", fontSize: 12 }}>{p.listing}</td>
                <td style={{ fontWeight: 700, color: "#00C853" }}>{fmtKES(p.amount)}</td>
                <td><span className={`badge ${p.status === "confirmed" ? "bg" : "bgr"}`}>{p.status}</span></td>
                <td style={{ color: "#555", fontSize: 12 }}>{p.date}</td>
                <td style={{ fontSize: 12, color: "#555", fontFamily: "monospace" }}>{p.receipt || "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
}

// ── CONFIRM MODAL ──────────────────────────────────────────────────────────────
function Confirm({ title, body, onConfirm, onClose, danger }) {
  return (
    <div className="modal-ov" onClick={e => e.target === e.currentTarget && onClose()}>
      <div className="modal">
        <div className="mh"><h3 style={{ fontSize: 16, fontWeight: 800 }}>{title}</h3><button className="btn bs bsm" onClick={onClose} style={{ padding: "4px 8px" }}>✕</button></div>
        <div className="mb"><p style={{ color: "#888", fontSize: 14, lineHeight: 1.6 }}>{body}</p></div>
        <div className="mf">
          <button className="btn bs" onClick={onClose}>Cancel</button>
          <button className={`btn ${danger ? "br" : "bp"}`} onClick={() => { onConfirm(); onClose(); }}>Confirm</button>
        </div>
      </div>
    </div>
  );
}

// ── TOAST ──────────────────────────────────────────────────────────────────────
function Toast({ msg, type, onClose }) {
  useEffect(() => { const t = setTimeout(onClose, 3500); return () => clearTimeout(t); }, []);
  const icon = type === "success" ? "✅" : type === "error" ? "❌" : "ℹ️";
  return (
    <div style={{ position: "fixed", bottom: 24, right: 24, zIndex: 2000, background: "#1E1E1E", border: "1px solid #333", borderRadius: 12, padding: "12px 18px", fontSize: 13, display: "flex", alignItems: "center", gap: 10, maxWidth: 340, boxShadow: "0 8px 30px rgba(0,0,0,.4)", animation: "su .25s ease" }}>
      {icon} {msg}
    </div>
  );
}

// ── MAIN ADMIN APP ─────────────────────────────────────────────────────────────
export default function AdminApp() {
  const [admin, setAdmin] = useState(null);
  const [activePage, setActivePage] = useState("overview");
  const [data, setData] = useState(DEMO);
  const [confirm, setConfirm] = useState(null);
  const [toast, setToast] = useState(null);

  const notify = useCallback((msg, type = "success") => setToast({ msg, type, id: Date.now() }), []);

  const NAV = [
    { id: "overview", icon: "📊", label: "Overview" },
    { id: "users", icon: "👥", label: "Users" },
    { id: "listings", icon: "📦", label: "Listings" },
    { id: "violations", icon: "🚨", label: "Violations", badge: data.violations.filter(v => !v.reviewed).length },
    { id: "escrow", icon: "🔐", label: "Escrow & Disputes", badge: data.disputes.filter(d => d.status === "open").length },
    { id: "payments", icon: "💳", label: "Payments" },
  ];

  const handleAction = (type, item) => {
    const actions = {
      suspend: () => { setData(p => ({ ...p, users: p.users.map(u => u.id === item.id ? { ...u, status: "suspended" } : u) })); notify(`${item.name} suspended.`); },
      unsuspend: () => { setData(p => ({ ...p, users: p.users.map(u => u.id === item.id ? { ...u, status: "active" } : u) })); notify(`${item.name} restored.`); },
      dismiss: () => { setData(p => ({ ...p, users: p.users.map(u => u.id === item.id ? { ...u, status: "active" } : u) })); notify(`Flag dismissed for ${item.name}.`); },
      dismiss_violation: () => { setData(p => ({ ...p, violations: p.violations.map(v => v.id === item.id ? { ...v, reviewed: true } : v) })); notify("Violation dismissed."); },
      warn_user: () => { setData(p => ({ ...p, violations: p.violations.map(v => v.id === item.id ? { ...v, reviewed: true } : v) })); notify(`Warning sent to ${item.user}.`); },
      suspend_user: () => { setData(p => ({ ...p, violations: p.violations.map(v => v.id === item.id ? { ...v, reviewed: true } : v), users: p.users.map(u => u.email === item.email ? { ...u, status: "suspended" } : u) })); notify(`${item.user} suspended.`); },
      release_escrow: () => { setData(p => ({ ...p, escrows: p.escrows.map(e => e.id === item.id ? { ...e, status: "released" } : e) })); notify(`Escrow released for ${item.listing}.`); },
      refund_escrow: () => { setData(p => ({ ...p, escrows: p.escrows.map(e => e.id === item.id ? { ...e, status: "refunded" } : e) })); notify(`Escrow refunded for ${item.listing}.`); },
      resolve_seller: () => { setData(p => ({ ...p, disputes: p.disputes.map(d => d.id === item.id ? { ...d, status: "resolved" } : d) })); notify("Dispute resolved in seller's favour."); },
      resolve_buyer: () => { setData(p => ({ ...p, disputes: p.disputes.map(d => d.id === item.id ? { ...d, status: "resolved" } : d) })); notify("Dispute resolved in buyer's favour."); },
    };
    if (actions[type]) {
      const dangerTypes = ["suspend", "suspend_user", "refund_escrow"];
      setConfirm({ title: "Confirm Action", body: `Are you sure you want to proceed with this action?`, onConfirm: actions[type], danger: dangerTypes.includes(type) });
    }
  };

  if (!admin) return <Login onLogin={setAdmin} />;

  return (
    <>
      <style>{CSS}</style>
      <div className="layout">
        {/* SIDEBAR */}
        <div className="sidebar">
          <div className="sidebar-logo">
            <h2>Weka<span>Soko</span></h2>
            <p>Admin Panel</p>
          </div>
          <div style={{ flex: 1, paddingTop: 12 }}>
            <div className="nav-section">Main</div>
            {NAV.map(n => (
              <div key={n.id} className={`nav-item ${activePage === n.id ? "active" : ""}`} onClick={() => setActivePage(n.id)}>
                <span className="icon">{n.icon}</span>
                <span style={{ flex: 1 }}>{n.label}</span>
                {n.badge > 0 && <span style={{ background: "#FF3D3D", color: "#fff", borderRadius: 10, padding: "1px 6px", fontSize: 10, fontWeight: 700 }}>{n.badge}</span>}
              </div>
            ))}
          </div>
          <div style={{ padding: "16px 20px", borderTop: "1px solid #1A1A1A" }}>
            <div style={{ fontSize: 12, color: "#555", marginBottom: 8 }}>Signed in as</div>
            <div style={{ fontSize: 13, fontWeight: 600 }}>{admin.name}</div>
            <div style={{ fontSize: 11, color: "#444", marginBottom: 12 }}>{admin.email}</div>
            <button className="btn bs bsm" style={{ width: "100%" }} onClick={() => setAdmin(null)}>Sign Out</button>
          </div>
        </div>

        {/* MAIN */}
        <div className="main">
          <div className="topbar">
            <div>
              <h3 style={{ fontSize: 15, fontWeight: 800 }}>{NAV.find(n => n.id === activePage)?.label}</h3>
              <p style={{ fontSize: 11, color: "#444", marginTop: 1 }}>Weka Soko Admin · {new Date().toLocaleDateString("en-KE", { weekday: "long", year: "numeric", month: "long", day: "numeric" })}</p>
            </div>
            <div style={{ display: "flex", gap: 10, alignItems: "center" }}>
              {data.violations.filter(v => !v.reviewed).length > 0 && (
                <button className="btn br bsm" onClick={() => setActivePage("violations")}>
                  🚨 {data.violations.filter(v => !v.reviewed).length} Violations
                </button>
              )}
              {data.disputes.filter(d => d.status === "open").length > 0 && (
                <button className="btn bo bsm" onClick={() => setActivePage("escrow")}>
                  ⚖️ {data.disputes.filter(d => d.status === "open").length} Disputes
                </button>
              )}
            </div>
          </div>

          <div className="content">
            {activePage === "overview" && <Overview data={data} />}
            {activePage === "users" && <Users data={data} onAction={handleAction} />}
            {activePage === "listings" && <Listings data={data} />}
            {activePage === "violations" && <Violations data={data} onAction={handleAction} />}
            {activePage === "escrow" && <Escrow data={data} onAction={handleAction} />}
            {activePage === "payments" && <Payments data={data} />}
          </div>
        </div>
      </div>

      {confirm && <Confirm {...confirm} onClose={() => setConfirm(null)} />}
      {toast && <Toast key={toast.id} msg={toast.msg} type={toast.type} onClose={() => setToast(null)} />}
    </>
  );
}
